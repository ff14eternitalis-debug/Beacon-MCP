# ===================================================
# Beacon MCP — Configuration
# Copiez ce fichier en .env et remplissez si besoin
# ===================================================

# --- API Beacon (optionnel) ---

# URL de base de l'API v4 (défaut : https://api.usebeacon.app/v4)
# BEACON_API_URL=https://api.usebeacon.app/v4

# Client ID OAuth (défaut : app web officielle Beacon)
# BEACON_CLIENT_ID=12877547-7ad0-466f-a001-77815043c96b

# --- Mode HTTP (pour ChatGPT Actions + clients SSE) ---

# Port d'écoute du serveur HTTP (défaut : 3333)
# PORT=3333

# Clé API pour protéger les endpoints HTTP (recommandé si exposé publiquement)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MCP_API_KEY=votre-cle-aleatoire-ici
